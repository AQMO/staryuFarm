[project]
requires = ["java-17"]

[dev]
build = ["bash", "-c", "mvn clean package -DskipTests"]
run = ["bash", "-c", "export PGDATABASE_URL && java -jar target/staryu-web.jar --server.port=5000"]

[deploy]
build = ["bash", "-c", "mvn clean package -DskipTests"]
run = ["bash", "-c", "export PGDATABASE_URL && java -jar target/staryu-web.jar --server.port=5000"]
